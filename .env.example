# Copiar este archivo como .env y completar valores locales.
# No subir .env real a GitHub.

# Flask
SECRET_KEY=cambiar-por-una-clave-larga-y-aleatoria
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
TEMPLATES_AUTO_RELOAD=true
# Opcional: URL publica temporal o dominio propio para tablets. Si se configura,
# el panel y el QR usaran esta URL en vez de la IP LAN.
TABLET_URL=

# Base de datos
# Por defecto usa evaluaciones.db en la raíz del proyecto.
# TeleECOE normaliza sqlite:///evaluaciones.db a ruta absoluta para evitar crear instance/evaluaciones.db.
DATABASE_URL=sqlite:///evaluaciones.db

# Video / RCP
# Visor: si se configura HLS, será el modo preferente. Si falla, cae a WebRTC/go2rtc.
# RCP_CAMERA_DEFAULT_MODE puede ser hls, webrtc, mse o auto. Vacío = hls si está configurado; si no, webrtc.
RCP_CAMERA_DEFAULT_MODE=
# URL HLS temporal/directa (.m3u8) generada por Tuya Cloud API, solo para pruebas locales.
RCP_CAMERA_HLS_URL=
# Alternativa recomendada para producción: comando local que imprima la URL HLS temporal
# como texto plano o JSON {"url":"https://...m3u8"}. No guardar secretos en Git.
# Ejemplo con el script incluido:
# RCP_CAMERA_HLS_URL_COMMAND=.venv-linux/bin/python scripts/tuya_hls_url.py --json
RCP_CAMERA_HLS_URL_COMMAND=
RCP_CAMERA_HLS_URL_TIMEOUT=15

# Tuya Cloud API para scripts/tuya_hls_url.py. Completar solo en .env local, nunca en Git.
TUYA_ENDPOINT=https://openapi.tuyaus.com
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_DEVICE_ID=
# Opcional. Si se deja vacío, usa /v1.0/devices/{device_id}/stream/actions/allocate.
TUYA_UID=
TUYA_STREAM_TYPE=hls
TUYA_GRANT_TYPE=1
TUYA_TIMEOUT=20

# Grabación/evidencia: se mantiene por go2rtc RTSP + FFmpeg transcode validado.
RECORDING_STREAM_URL=rtsp://127.0.0.1:8554/camara1
MAX_RECORDING_SECONDS=3600
WARMUP_SECONDS=5
RECORDING_FPS=15
RECORDING_SCALE=1280:720
RECORDING_VIDEO_BITRATE=1800k
RECORDING_VIDEO_MAXRATE=2200k
RECORDING_VIDEO_BUFSIZE=3600k
RECORDING_PRESET=veryfast

# FFmpeg/FFprobe local. Si se deja vacío, la app usa tools/ffmpeg-static/.
FFMPEG_BIN=
FFPROBE_BIN=

# Validación mínima de video RCP antes de asociarlo como evidencia.
MIN_VALID_VIDEO_BYTES=1024
MIN_VALID_VIDEO_DURATION=0.5
